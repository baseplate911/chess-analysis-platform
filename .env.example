# Chess Analysis Platform — Environment Variables
# Copy this file to .env and fill in the values
# cp .env.example .env

# ─── Security ─────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Change this to a long random string!
SECRET_KEY=your-secret-key-here-change-in-production

# ─── Stockfish ────────────────────────────────────────────────────────────────
# Path to Stockfish executable (optional — analysis falls back to heuristics)
# Linux:   /usr/games/stockfish  or  /usr/local/bin/stockfish
# macOS:   /usr/local/bin/stockfish  (after: brew install stockfish)
# Windows: C:\stockfish\stockfish.exe
STOCKFISH_PATH=C:\stockfish\stockfish.exe

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite is used by default (no external DB needed)
# To use PostgreSQL: postgresql://user:password@localhost:5432/chess_db
DATABASE_URL=sqlite:///./chess_analysis.db

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL of the React frontend (used for CORS)
FRONTEND_URL=http://localhost:3000

# ─── JWT Settings (optional overrides) ────────────────────────────────────────
# Algorithm used for JWT signing
JWT_ALGORITHM=HS256
# Token expiry in days
ACCESS_TOKEN_EXPIRE_DAYS=30
